# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=
# OPENAI_API_VERSION=2024-10-21  # optional, required for non-v1 API

# AWS Bedrock
# Uses standard boto3 credential chain (env vars, ~/.aws/credentials, IAM role, etc.)
# Set llm_provider="bedrock" in config. Model aliases: claude-haiku, claude-sonnet, claude-opus
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=                # optional, for temporary credentials
# AWS_PROFILE=                      # optional, named profile from ~/.aws/credentials
